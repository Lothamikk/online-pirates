@page "/tools-pages/password"

<MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-6">🎲 Генератор паролей</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard Elevation="4">
            <MudCardContent>
                <MudText Typo="Typo.body2" Class="mt-3">Длина пароля: <b>@passwordLength</b></MudText>
                <MudSlider @bind-Value="passwordLength" Min="8" Max="64" Step="1" Color="Color.Primary" />
                <MudCheckBox T="bool" @bind-Checked="useUpper" Label="Заглавные (A-Z)" Color="Color.Primary" />
                <MudCheckBox T="bool" @bind-Checked="useNumbers" Label="Цифры (0-9)" Color="Color.Tertiary" />
                <MudCheckBox T="bool" @bind-Checked="useSymbols" Label="Символы" Color="Color.Error" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GeneratePassword" FullWidth="true">
                    Сгенерировать
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="6">
        @if (!string.IsNullOrEmpty(generatedPassword))
        {
            <MudPaper Elevation="4" Class="pa-4">
                <MudText Typo="Typo.h5">Твой пароль:</MudText>
                <MudTextField T="string" Text="@generatedPassword" ReadOnly="true" Variant="Variant.Outlined" Class="mt-3" />
                <MudChip T="string" Color="Color.Success" Class="mt-2">Надёжность: @GetStrength()</MudChip>
            </MudPaper>
        }
    </MudItem>
</MudGrid>

@code {
    private string generatedPassword = "";
    private int passwordLength = 16;
    private bool useUpper = true;
    private bool useNumbers = true;
    private bool useSymbols = true;

    private void GeneratePassword()
    {
        const string lower = "abcdefghijklmnopqrstuvwxyz";
        const string upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
        const string numbers = "0123456789";
        const string symbols = "!@#$%^&*()_+-=[]{}|;:,.<>?";
        string chars = lower;
        if (useUpper) chars += upper;
        if (useNumbers) chars += numbers;
        if (useSymbols) chars += symbols;
        var rand = new Random();
        generatedPassword = new string(Enumerable.Range(0, passwordLength).Select(_ => chars[rand.Next(chars.Length)]).ToArray());
    }

    private string GetStrength() => passwordLength switch { < 10 => "Слабая", < 16 => "Средняя", < 24 => "Хорошая", _ => "Отличная" };
}