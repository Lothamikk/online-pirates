@using MudBlazor
@using DarkPortal.Models
<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_title" Label="Заголовок" />
        <MudTextField @bind-Value="_summary" Label="Краткое описание" Lines="2" Class="mt-3" />
        <MudTextField @bind-Value="_source" Label="Источник" Class="mt-3" />
        <MudTextField @bind-Value="_category" Label="Категория" Class="mt-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Отмена</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save">Добавить</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = default!;
    private string _title = "", _summary = "", _source = "", _category = "";

    private void Save()
    {
        var news = new NewsItem
        {
            Title = _title,
            Summary = _summary,
            Source = _source,
            Category = _category,
            PublishedAt = DateTime.UtcNow
        };
        MudDialog.Close(DialogResult.Ok(news));
    }

    private void Cancel() => MudDialog.Cancel();
}