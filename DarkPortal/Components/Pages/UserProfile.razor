@page "/profile/{UserId}"

@using DarkPortal.Models
@using DarkPortal.Services
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject UserManager<AppUser> UserManager
@inject ProfileService ProfileService
@inject AdminService AdminService
@inject AchievementService AchievementService
@inject FriendService FriendService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthProvider

<PageTitle>Профиль — Online Pirates</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">

    @if (_profile == null)
    {
        <MudPaper Class="pa-6" Elevation="3">
            <MudText Typo="Typo.h4" Class="mb-4">Профиль не найден</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoHome">
                На главную
            </MudButton>
        </MudPaper>
        return;
    }

    @* ===== БАННЕР ===== *@
    <div style="width:100%;height:200px;border-radius:16px;overflow:hidden;margin-bottom:-60px;position:relative;z-index:0;
        background:@_bannerStyle;display:flex;align-items:center;justify-content:center;">
        @if (string.IsNullOrEmpty(_profile.BannerUrl))
        {
            <MudText Typo="Typo.h3" Style="color:rgba(255,255,255,0.3);font-family:'JetBrains Mono',monospace;font-size:48px;font-weight:700;">
                @(_profile.DisplayName ?? _profile.UserName)
            </MudText>
        }
        @if (_isOwner && _editing)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                           Style="position:absolute;top:12px;right:12px;background:rgba(0,0,0,0.5);"
                           Color="Color.Inherit" Size="Size.Small"
                           OnClick="StartEditingBanner" />
        }
    </div>

    <MudPaper Class="pa-6" Elevation="3" Style="position:relative;z-index:1;padding-top:70px;">

        @* ===== АВАТАР + ИНФО ===== *@
        <div style="display:flex;align-items:flex-start;gap:24px;flex-wrap:wrap;">

            @* Аватар *@
            <div style="position:relative;margin-top:-80px;">
                <div style="width:120px;height:120px;border-radius:50%;border:3px solid var(--border);overflow:hidden;
                    background:@_avatarStyle;display:flex;align-items:center;justify-content:center;">
                    @if (string.IsNullOrEmpty(_profile.AvatarUrl))
                    {
                        <span style="color:#FFFFFF;font-size:48px;font-weight:700;font-family:'JetBrains Mono',monospace;">
                            @(_profile.DisplayName?.FirstOrDefault().ToString().ToUpper() ?? _profile.UserName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                        </span>
                    }
                </div>
                @if (_isOwner && _editing)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.CameraAlt"
                                   Style="position:absolute;bottom:0;right:0;background:rgba(0,0,0,0.7);"
                                   Color="Color.Inherit" Size="Size.Small"
                                   OnClick="StartEditingAvatar" />
                }
            </div>

            @* Инфо *@
            <div style="flex:1;min-width:200px;">
                <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
                    <MudText Typo="Typo.h4" Style="@_displayNameStyle">
                        @(_profile.DisplayName ?? _profile.UserName)
                    </MudText>

                    @if (_isBanned)
                    {
                        <span style="font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;
                            color:#EF4444;background:rgba(239,68,68,0.15);
                            border:1px solid rgba(239,68,68,0.3);
                            padding:4px 12px;border-radius:20px;letter-spacing:0.05em;">
                            🚫 ЗАБЛОКИРОВАН
                        </span>
                    }

                    @if (_showAdminBadge)
                    {
                        <span style="font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:600;
                            color:@(_isChiefAdmin ? "#EF4444" : "#60A5FA");
                            background:@(_isChiefAdmin ? "rgba(239,68,68,0.15)" : "rgba(96,165,250,0.15)");
                            border:1px solid @(_isChiefAdmin ? "rgba(239,68,68,0.3)" : "rgba(96,165,250,0.3)");
                            padding:4px 12px;border-radius:20px;letter-spacing:0.05em;">
                            @(_isChiefAdmin ? "CHIEF ADMIN" : "ADMIN")
                        </span>
                    }

                    @if (_pinnedBadge != null)
                    {
                        <MudTooltip Text="@_pinnedBadge.Name">
                            <MudIcon Icon="@_pinnedBadge.Icon"
                                     Color="@_pinnedBadgeColor"
                                     Style="font-size:24px;" />
                        </MudTooltip>
                    }
                </div>

                <MudText Typo="Typo.body2" Style="color:var(--text-secondary);font-size:0.9rem;">
                    @@@_profile.UserName
                </MudText>

                @if (!_editing && !string.IsNullOrEmpty(_profile.Bio))
                {
                    <MudText Typo="Typo.body1" Class="mt-2" Style="color:var(--text-main);">@_profile.Bio</MudText>
                }

                @* ===== ПОЛЯ РЕДАКТИРОВАНИЯ ===== *@
                @if (_editing)
                {
                    <div class="mt-3" style="display:flex;flex-direction:column;gap:12px;max-width:500px;">
                        <MudTextField @bind-Value="_editDisplayName"
                                      Label="Отображаемое имя"
                                      Variant="Variant.Outlined"
                                      MaxLength="15"
                                      Immediate="true"
                                      HelperText="@($"{(_editDisplayName?.Length ?? 0)}/15")" />
                        <MudTextField @bind-Value="_editBio"
                                      Label="О себе"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      MaxLength="85"
                                      Immediate="true"
                                      HelperText="@($"{(_editBio?.Length ?? 0)}/85")" />

                        @if (_showBannerInput)
                        {
                            <MudTextField @bind-Value="_editBannerUrl"
                                          Label="URL баннера"
                                          Variant="Variant.Outlined"
                                          HelperText="Вставьте ссылку на изображение" />
                        }

                        @if (_showAvatarInput)
                        {
                            <MudTextField @bind-Value="_editAvatarUrl"
                                          Label="URL аватара"
                                          Variant="Variant.Outlined"
                                          HelperText="Вставьте ссылку на изображение" />
                        }

                        <div style="display:flex;gap:8px;">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       OnClick="SaveProfile"
                                       Style="background-color:#2E8B57;color:#FFFFFF;">
                                Сохранить
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" OnClick="CancelEditing" Style="color:var(--text-main);border-color:var(--border);">
                                Отмена
                            </MudButton>
                        </div>
                    </div>
                }

                @if (!_editing)
                {
                    <div class="mt-3" style="display:flex;gap:8px;flex-wrap:wrap;">
                        @if (_isOwner)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       Size="Size.Small"
                                       OnClick="StartEditing"
                                       Style="background-color:#2E8B57;color:#FFFFFF;">
                                Редактировать профиль
                            </MudButton>

                            @if (_pinnedBadge != null)
                            {
                                <MudButton Variant="Variant.Outlined"
                                           Size="Size.Small"
                                           OnClick="UnpinBadge"
                                           Style="color:#EF4444;border-color:#EF4444;">
                                    Убрать значок
                                </MudButton>
                            }
                        }

                        @* Кнопка друзей видна всем *@
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Href="@($"/friends/{UserId}")"
                                   Style="color:var(--text-main);border-color:var(--border);">
                            Друзья (@_friendCount)
                        </MudButton>

                        @if (!_isOwner && _isLoggedIn)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="ToggleFriend">
                                @(_isFriend ? "В друзьях" : _isPending ? "Заявка отправлена" : "Добавить в друзья")
                            </MudButton>
                        }
                    </div>
                }
            </div>
        </div>

        @* ===== ДОСТИЖЕНИЯ ===== *@
        @if (_achievements.Any())
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.h6" Class="mb-3" Style="font-family:'JetBrains Mono',monospace;color:var(--text-main);">Достижения</MudText>
            <div style="display:flex;gap:16px;flex-wrap:wrap;align-items:center;">
                @foreach (var ach in _achievements)
                {
                    <MudTooltip Text="@ach.Description">
                        <div style="display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;
                            opacity:@(ach.Unlocked ? "1" : "0.3");
                            @(ach == _pinnedBadge ? "background:rgba(46,139,87,0.15);border:1px solid #2E8B57;" : "")
                            padding:8px;border-radius:12px;min-width:60px;"
                             @onclick="@(() => ach.Unlocked ? PinBadge(ach) : null)">
                            <MudIcon Icon="@ach.Icon"
                                     Style="font-size:28px;"
                                     Color="@(ach.Unlocked ? GetBadgeColor(ach) : Color.Default)" />
                            <span style="font-size:10px;color:var(--text-secondary);text-align:center;max-width:60px;word-break:break-word;">
                                @ach.Name.Split(' ').FirstOrDefault()
                            </span>
                            @if (!ach.Unlocked)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size:12px;color:var(--text-secondary);" />
                            }
                        </div>
                    </MudTooltip>
                }
            </div>
        }
    </MudPaper>

    @* ===== КОММЕНТАРИИ ===== *@
    <MudPaper Class="pa-6 mt-4" Elevation="3">
        <MudText Typo="Typo.h6" Class="mb-4" Style="font-family:'JetBrains Mono',monospace;color:var(--text-main);">Комментарии (@_comments.Count)</MudText>

        @if (_isLoggedIn)
        {
            <div style="display:flex;gap:12px;margin-bottom:16px;">
                <MudTextField @bind-Value="_newComment"
                              Label="Написать комментарий..."
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Lines="2" />
                <MudButton Variant="Variant.Filled" Color="Color.Success"
                           OnClick="AddComment"
                           Disabled="@string.IsNullOrWhiteSpace(_newComment)"
                           Style="background-color:#2E8B57;color:#FFFFFF;">
                    Отправить
                </MudButton>
            </div>
        }

        @foreach (var comment in _comments)
        {
            <div style="background:var(--card-bg);border-radius:8px;padding:12px;margin-bottom:8px;border:1px solid var(--border);">
                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                    <MudLink Href="@($"/profile/{comment.AuthorId}")" Typo="Typo.body2" Style="font-weight:600;color:var(--text-main);">
                        @comment.AuthorName
                    </MudLink>
                    <div style="display:flex;align-items:center;gap:8px;">
                        <MudText Typo="Typo.caption" Style="color:var(--text-secondary);">
                            @comment.CreatedAt.AddHours(3).ToString("dd.MM.yyyy HH:mm")
                        </MudText>
                        @if (_isOwner || _isAdmin)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => DeleteComment(comment.Id))" />
                        }
                    </div>
                </div>
                <MudText Typo="Typo.body2" Style="color:var(--text-main);">@comment.Content</MudText>
            </div>
        }

        @if (!_comments.Any())
        {
            <MudText Typo="Typo.body2" Style="color:var(--text-secondary);text-align:center;padding:20px;">
                Пока нет комментариев
            </MudText>
        }
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public string? UserId { get; set; }

    private AppUser? _profile;
    private List<ProfileComment> _comments = new();
    private List<Achievement> _achievements = new();
    private Achievement? _pinnedBadge;
    private Color _pinnedBadgeColor = Color.Default;
    private List<string> _roles = new();
    private bool _isOwner;
    private bool _isLoggedIn;
    private bool _isFriend;
    private bool _isPending;
    private bool _showAdminBadge;
    private bool _isChiefAdmin;
    private bool _isAdmin;
    private bool _isBanned;
    private string _newComment = "";
    private string _bannerStyle = "";
    private string _avatarStyle = "";
    private int _friendCount;
    private string _displayNameStyle => $"font-weight:600;color:{(_isChiefAdmin ? "#EF4444" : _showAdminBadge ? "#60A5FA" : "var(--text-main)")}";

    private bool _editing = false;
    private bool _showBannerInput = false;
    private bool _showAvatarInput = false;
    private string _editDisplayName = "";
    private string _editBio = "";
    private string _editBannerUrl = "";
    private string _editAvatarUrl = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_profile?.Id != UserId)
        {
            await LoadProfile();
        }
    }

    private async Task LoadProfile()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var currentUserId = state.User.FindFirstValue(ClaimTypes.NameIdentifier);
        _isLoggedIn = !string.IsNullOrEmpty(currentUserId);
        _isOwner = currentUserId == UserId;

        var user = await AdminService.GetUserByIdAsync(UserId);
        if (user == null) return;
        _profile = user;

        _roles = (await UserManager.GetRolesAsync(_profile)).ToList();
        _showAdminBadge = _roles.Contains("Admin");
        _isChiefAdmin = _profile.UserName == "admin";
        _isAdmin = _roles.Contains("Admin");
        _isBanned = _profile.LockoutEnd > DateTimeOffset.UtcNow;

        _achievements = await AchievementService.GetAchievements(UserId!);
        _pinnedBadge = _achievements.FirstOrDefault(a => a.Icon == _profile.PinnedBadge && a.Unlocked);
        if (_pinnedBadge != null)
        {
            _pinnedBadgeColor = GetColorFromString(_pinnedBadge.Color);
        }

        _comments = await ProfileService.GetCommentsAsync(UserId!);
        _friendCount = await FriendService.GetFriendCount(UserId!);

        if (!_isOwner && _isLoggedIn)
        {
            _isFriend = await FriendService.IsFriend(currentUserId!, UserId!);
            _isPending = await FriendService.HasPendingRequest(currentUserId!, UserId!);
        }

        UpdateStyles();
        _editing = false;
        StateHasChanged();
    }

    private void UpdateStyles()
    {
        _bannerStyle = string.IsNullOrEmpty(_profile?.BannerUrl)
            ? "linear-gradient(135deg, #1a1a2e, #16213e)"
            : $"url({_profile.BannerUrl}) center/cover";

        _avatarStyle = string.IsNullOrEmpty(_profile?.AvatarUrl)
                    ? "linear-gradient(135deg, #2E8B57, #181C24)"
                    : $"url({_profile.AvatarUrl}) center/cover";
    }

    private Color GetColorFromString(string color)
    {
        return color?.ToLower() switch
        {
            "success" or "green" => Color.Success,
            "primary" or "blue" => Color.Primary,
            "secondary" or "gray" => Color.Secondary,
            "tertiary" or "purple" => Color.Tertiary,
            "warning" or "yellow" => Color.Warning,
            "error" or "red" => Color.Error,
            _ => Color.Tertiary
        };
    }

    private Color GetBadgeColor(Achievement ach) => GetColorFromString(ach.Color);

    private async Task PinBadge(Achievement badge)
    {
        if (!_isOwner || _profile == null || !badge.Unlocked) return;
        _profile.PinnedBadge = badge.Icon;
        _pinnedBadge = badge;
        _pinnedBadgeColor = GetColorFromString(badge.Color);
        await UserManager.UpdateAsync(_profile);
        Snackbar.Add("Значок закреплён", Severity.Success);
    }

    private async Task UnpinBadge()
    {
        if (!_isOwner || _profile == null) return;
        _profile.PinnedBadge = null;
        _pinnedBadge = null;
        await UserManager.UpdateAsync(_profile);
        Snackbar.Add("Значок убран", Severity.Success);
    }

    private async Task ToggleFriend()
    {
        if (!_isLoggedIn || _isOwner) return;
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var currentUserId = state.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (_isFriend)
        {
            await FriendService.RemoveFriend(currentUserId!, UserId!);
            _isFriend = false;
            Snackbar.Add("Удалён из друзей", Severity.Info);
        }
        else if (_isPending)
        {
            await FriendService.RemoveFriend(currentUserId!, UserId!);
            _isPending = false;
            Snackbar.Add("Заявка отменена", Severity.Info);
        }
        else
        {
            await FriendService.SendRequest(currentUserId!, UserId!);
            _isPending = true;
            Snackbar.Add("Заявка отправлена", Severity.Success);
        }
    }

    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(_newComment)) return;
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var authorId = state.User.FindFirstValue(ClaimTypes.NameIdentifier);
        var authorName = state.User.Identity?.Name ?? "Аноним";

        await ProfileService.AddCommentAsync(UserId!, authorId!, authorName, _newComment);
        _newComment = "";
        _comments = await ProfileService.GetCommentsAsync(UserId!);
        Snackbar.Add("Комментарий добавлен", Severity.Success);
    }

    private async Task DeleteComment(int commentId)
    {
        await ProfileService.DeleteCommentAsync(commentId);
        _comments = await ProfileService.GetCommentsAsync(UserId!);
        Snackbar.Add("Комментарий удалён", Severity.Info);
    }

    private void StartEditing()
    {
        _editing = true;
        _editDisplayName = _profile?.DisplayName ?? "";
        _editBio = _profile?.Bio ?? "";
        _showBannerInput = false;
        _showAvatarInput = false;
    }

    private void StartEditingBanner()
    {
        _editBannerUrl = _profile?.BannerUrl ?? "";
        _showBannerInput = true;
    }

    private void StartEditingAvatar()
    {
        _editAvatarUrl = _profile?.AvatarUrl ?? "";
        _showAvatarInput = true;
    }

    private async Task SaveProfile()
    {
        if (_profile == null) return;

        var name = _editDisplayName?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(name) || name.Length < 3 || name.Length > 15)
        {
            Snackbar.Add("Имя должно быть от 3 до 15 символов", Severity.Error);
            return;
        }

        _profile.DisplayName = name;
        _profile.Bio = _editBio?[..Math.Min(_editBio.Length, 85)];
        if (_showBannerInput) _profile.BannerUrl = _editBannerUrl;
        if (_showAvatarInput) _profile.AvatarUrl = _editAvatarUrl;

        await UserManager.UpdateAsync(_profile);
        _editing = false;
        _showBannerInput = false;
        _showAvatarInput = false;
        UpdateStyles();
        Snackbar.Add("Профиль обновлён", Severity.Success);
    }

    private void CancelEditing()
    {
        _editing = false;
        _showBannerInput = false;
        _showAvatarInput = false;
    }

    private void GoHome() => Navigation.NavigateTo("/");
}