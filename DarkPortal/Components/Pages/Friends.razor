@page "/friends"
@rendermode InteractiveServer
@using DarkPortal.Models
@using DarkPortal.Services
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject FriendService FriendService
@inject DarkPortal.Services.NotificationService NotificationService
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<PageTitle>Друзья — Online Pirates</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
    <MudText Typo="Typo.h4" Class="mb-4" Style="font-weight:600;">Друзья</MudText>

    @if (_friends.Any())
    {
        @foreach (var friend in _friends)
        {
            <div style="display:flex;align-items:center;gap:12px;padding:12px;background:var(--card-bg);border-radius:12px;margin-bottom:8px;border:1px solid var(--border);">
                <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#2E8B57,#181C24);display:flex;align-items:center;justify-content:center;color:#FFF;font-weight:700;font-family:'JetBrains Mono',monospace;flex-shrink:0;">
                    @(friend.DisplayName?.FirstOrDefault().ToString().ToUpper() ?? friend.UserName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                </div>
                <MudLink Href="@($"/profile/{friend.Id}")" Typo="Typo.body1" Style="font-weight:600;flex:1;">
                    @(friend.DisplayName ?? friend.UserName)
                </MudLink>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => RemoveFriend(friend.Id))" />
            </div>
        }
    }
    else
    {
        <MudText Typo="Typo.body1" Color="Color.Secondary" Style="text-align:center;padding:40px;">
            Список друзей пуст
        </MudText>
    }

    @if (_pendingRequests.Any())
    {
        <MudText Typo="Typo.h5" Class="mt-6 mb-3" Style="font-weight:600;">Заявки в друзья</MudText>
        @foreach (var req in _pendingRequests)
        {
            <div style="display:flex;align-items:center;gap:12px;padding:12px;background:var(--card-bg);border-radius:12px;margin-bottom:8px;border:1px solid var(--border);">
                <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#2E8B57,#181C24);display:flex;align-items:center;justify-content:center;color:#FFF;font-weight:700;font-family:'JetBrains Mono',monospace;flex-shrink:0;">
                    @(req.DisplayName?.FirstOrDefault().ToString().ToUpper() ?? req.UserName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                </div>
                <MudLink Href="@($"/profile/{req.Id}")" Typo="Typo.body1" Style="font-weight:600;flex:1;">
                    @(req.DisplayName ?? req.UserName)
                </MudLink>
                <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" OnClick="@(() => AcceptRequest(req.Id))" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Error" OnClick="@(() => RejectRequest(req.Id))" />
            </div>
        }
    }
</MudContainer>

@code {
    private List<AppUser> _friends = new();
    private List<AppUser> _pendingRequests = new();
    private string _userId = "";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        _userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";

        if (string.IsNullOrEmpty(_userId))
        {
            Navigation.NavigateTo("/auth");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        _friends = await FriendService.GetFriends(_userId);
        _pendingRequests = await FriendService.GetPendingRequests(_userId);
    }

    private async Task RemoveFriend(string friendId)
    {
        await FriendService.RemoveFriend(_userId, friendId);
        await LoadData();
    }

    private async Task AcceptRequest(string friendId)
    {
        await FriendService.AcceptRequest(_userId, friendId);
        NotificationService.ClearAll(_userId);
        await LoadData();
    }

    private async Task RejectRequest(string friendId)
    {
        await FriendService.RemoveFriend(_userId, friendId);
        NotificationService.ClearAll(_userId);
        await LoadData();
    }
}