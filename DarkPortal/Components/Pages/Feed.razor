@page "/feed"
@inject DarkPortal.Services.NewsService NewsService
@inject DarkPortal.Services.LocaleService Loc

<MudText Typo="Typo.h4" Color="Color.Primary">
    <MudIcon Icon="@Icons.Material.Filled.Radar" /> @Loc.T("feed.title")
</MudText>
<MudText Typo="Typo.body1" Class="mt-2 mb-4">@Loc.T("feed.subtitle")</MudText>

<MudChipSet T="string" Filter="true" Class="mb-4">
    <MudChip T="string" Text="@Loc.T("feed.all")" Selected="@isAllSelected" OnClick="SelectAll" />
    <MudChip T="string" Text="@Loc.T("feed.leaks")" Selected="@isLeaksSelected" OnClick="SelectLeaks" />
    <MudChip T="string" Text="@Loc.T("feed.threats")" Selected="@isThreatsSelected" OnClick="SelectThreats" />
    <MudChip T="string" Text="@Loc.T("feed.vuln")" Selected="@isVulnSelected" OnClick="SelectVuln" />
</MudChipSet>

<div class="mb-4">
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="RefreshNews"
               StartIcon="@Icons.Material.Filled.Refresh" Disabled="@isRefreshing">
        @(isRefreshing ? Loc.T("feed.refreshing") : Loc.T("feed.refresh"))
    </MudButton>
</div>

@if (isLoading || isRefreshing)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="my-10" />
}
else if (!filteredNews.Any())
{
    <MudAlert Severity="Severity.Info">@Loc.T("feed.empty")</MudAlert>
}

@foreach (var news in filteredNews)
{
    <MudCard Elevation="3" Class="mb-4">
        <MudCardContent>
            <MudText Typo="Typo.h6">
                @if (!string.IsNullOrEmpty(news.Link))
                {
                    <a href="@news.Link" target="_blank" style="color:inherit;text-decoration:none;">@news.Title</a>
                }
                else
                {
                    @news.Title
                }
                @if (news.Severity == "Critical")
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="ml-2">Критическое</MudChip>
                }
                else if (news.Severity == "Warning")
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="ml-2">Важное</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Class="ml-2">Инфо</MudChip>
                }
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-2">@Truncate(news.Summary, 200)</MudText>
        </MudCardContent>
        <MudCardActions>
            <MudChip T="string" Size="Size.Small" Color="Color.Secondary">@news.Source</MudChip>
            <MudChip T="string" Size="Size.Small" Color="Color.Tertiary">@news.Category</MudChip>
            <MudSpacer />
            <MudText Typo="Typo.caption" Color="Color.Secondary">@GetTimeAgo(news.PublishedAt)</MudText>
        </MudCardActions>
    </MudCard>
}

@code {
    private List<Models.NewsItem> allNews = new();
    private List<Models.NewsItem> filteredNews = new();
    private string? selectedCategory = null;
    private bool isLoading = true;
    private bool isRefreshing = false;

    private bool isAllSelected => selectedCategory == null;
    private bool isLeaksSelected => selectedCategory == "Утечки";
    private bool isThreatsSelected => selectedCategory == "Угрозы";
    private bool isVulnSelected => selectedCategory == "Уязвимости";

    protected override async Task OnInitializedAsync()
    {
        await LoadNews();
    }

    private async Task LoadNews()
    {
        allNews = await NewsService.GetLatestNewsAsync();
        ApplyFilter();
        isLoading = false;
    }

    private async Task RefreshNews()
    {
        isRefreshing = true;
        StateHasChanged();

        await NewsService.ClearAndReloadAsync();

        // Ждём 15 секунд, чтобы фоновик успел загрузить новости
        await Task.Delay(15000);

        await LoadNews();
        isRefreshing = false;
        StateHasChanged();
    }

    private void SelectAll() { selectedCategory = null; ApplyFilter(); }
    private void SelectLeaks() { selectedCategory = "Утечки"; ApplyFilter(); }
    private void SelectThreats() { selectedCategory = "Угрозы"; ApplyFilter(); }
    private void SelectVuln() { selectedCategory = "Уязвимости"; ApplyFilter(); }

    private void ApplyFilter()
    {
        filteredNews = string.IsNullOrEmpty(selectedCategory)
            ? allNews
            : allNews.Where(n => n.Category == selectedCategory).ToList();
    }

    private string Truncate(string text, int max)
    {
        if (string.IsNullOrEmpty(text)) return "";
        return text.Length <= max ? text : text[..max] + "...";
    }

    private string GetTimeAgo(DateTime time)
    {
        var diff = DateTime.UtcNow - time;
        if (diff.TotalMinutes < 1) return "только что";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes} мин. назад";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} ч. назад";
        return $"{(int)diff.TotalDays} дн. назад";
    }
}