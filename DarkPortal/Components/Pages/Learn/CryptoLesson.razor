@page "/learn/crypto-lesson"
@rendermode InteractiveServer
@inject DarkPortal.Services.LocaleService Loc
@inject DarkPortal.Services.LessonService LessonService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthProvider
@inject NavigationManager Navigation

<MudText Typo="Typo.h4" Color="Color.Primary">💰 Урок 9: Криптовалюта и анонимность</MudText>
<MudAlert Severity="Severity.Info" Class="mt-4 mb-4">Bitcoin — псевдонимный. Monero — анонимный.</MudAlert>

<MudCard Elevation="4" Class="mb-4"><MudCardContent><MudText Typo="Typo.h6">📖 Bitcoin vs Monero</MudText><MudText Typo="Typo.body1">Bitcoin: все транзакции видны. Monero: скрыто всё.</MudText></MudCardContent></MudCard>

<MudCard Elevation="4" Class="mb-4"><MudCardContent><MudText Typo="Typo.h6">🕵️ Как платить анонимно?</MudText><MudText Typo="Typo.body1">Купи Bitcoin → обменяй на Monero → кошелёк → плати.</MudText><MudRadioGroup T="string" @bind-Value="_useMonero" Class="mt-2"><MudRadio T="string" Value="@("yes")" Color="Color.Success">Буду использовать Monero</MudRadio><MudRadio T="string" Value="@("no")" Color="Color.Warning">Пока не нужно</MudRadio></MudRadioGroup></MudCardContent></MudCard>

<MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="CompleteLesson" Class="mt-4" FullWidth="true">✅ Завершить урок</MudButton>

@code {
    private string _useMonero = "", _userId = "";

    protected override async Task OnInitializedAsync()
    {
        var a = await AuthProvider.GetAuthenticationStateAsync();
        _userId = a.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        if (string.IsNullOrEmpty(_userId)) { Navigation.NavigateTo("/auth"); return; }
        if (!await LessonService.CanAccessLesson(_userId, "crypto-lesson")) { Navigation.NavigateTo("/lessons"); return; }
    }

    private async Task CompleteLesson()
    {
        if (!string.IsNullOrEmpty(_userId)) await LessonService.MarkCompleted(_userId, "crypto-lesson");
        Navigation.NavigateTo("/", forceLoad: true);
    }
}